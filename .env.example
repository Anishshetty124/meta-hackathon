# LLM endpoint (required by hackathon instructions)
API_BASE_URL=https://api-inference.huggingface.co/openai/v1

# Environment endpoint (step/reset/state API)
ENV_BASE_URL=http://localhost:8000

# LLM Configuration
MODEL_NAME=meta-llama/Llama-2-7b-chat
HF_TOKEN=your_huggingface_token_here

# Optional compatibility key name
OPENAI_API_KEY=

# Optional deterministic local baseline mode
# Set to "heuristic" to run without LLM calls
BASELINE_MODE=

# Optional: Server configuration
DEBUG=False
LOG_LEVEL=INFO
